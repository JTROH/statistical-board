# Copy this file to `.env` and add your key to run the *standalone* board
# (`python -m stat_board …` or the web UI). The `.env` file is gitignored.
#
# NOT needed for: the statistics engine, the desktop GUI, the engine CLI, or the
# Claude Code skills — those run with no API key.

ANTHROPIC_API_KEY=sk-ant-...

# Optional tuning (defaults shown):
# STAT_MODEL=claude-opus-4-8
# STAT_EFFORT=high            # low | medium | high | max
# STAT_MAX_ROUNDS=2
# STAT_MAX_TOKENS=16000
# STAT_JUDGE_MAX_TOKENS=24000
